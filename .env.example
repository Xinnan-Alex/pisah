# Pisah backend — copy to .env and fill in. Load with your runner, e.g.:
#   export $(grep -v '^#' .env | xargs) && go run .

# Supabase Postgres connection string (Project Settings → Database → Connection string).
# Use the pooler / "Transaction" string for serverless/many-connection hosts.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Supabase project URL — used to fetch JWKS and verify owner access tokens (ES256).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Publishable key — Go backend sends this on the apikey header for owner sign-in.
# Settings → API Keys → Publishable and secret API keys (sb_publishable_...).
SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key (sb_secret_...) — server-side Storage (DuitNow QR + receipt scans).
# See SUPABASE_SECRET_KEY below.

# Legacy anon JWT — local supabase start only; prod uses SUPABASE_PUBLISHABLE_KEY.
# SUPABASE_ANON_KEY=

# Legacy HS256 shared secret. Optional — only needed if your project still issues
# HS256 user tokens. Modern projects use asymmetric (ES256) keys via SUPABASE_URL.
SUPABASE_JWT_SECRET=

# Base URL used to build friend share links: <PUBLIC_BASE_URL>/r/<slug>
PUBLIC_BASE_URL=https://split.my

PORT=8080

# Logging: debug | info | warn | error. Format: text (default) or json.
LOG_LEVEL=info
LOG_FORMAT=text

# Receipt OCR — AWS Bedrock (default). Uses AWS credentials / ECS task role.
AWS_REGION=ap-southeast-1
OCR_PROVIDER=bedrock
OCR_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
OCR_TIMEOUT=45s
# AWS_ACCESS_KEY_ID=      # local dev only; ECS uses task role
# AWS_SECRET_ACCESS_KEY=

# Legacy OpenAI fallback (set OCR_PROVIDER=openai):
# OPENAI_API_KEY=
# OCR_MODEL=gpt-4o-mini

# Supabase secret key — required for DuitNow QR and receipt scan image storage.
SUPABASE_SECRET_KEY=
