# Copy to terraform.tfvars (gitignored) and fill in.

# Supabase SESSION-pooler string with your DB password (Dashboard → Settings →
# Database → Connection string → Session pooler, port 5432).
database_url = "postgresql://postgres.zqvkqcphgncaelrlvcbs:YOUR_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

supabase_url = "https://zqvkqcphgncaelrlvcbs.supabase.co"

# Settings → API Keys → Publishable and secret API keys (create new keys if needed)
supabase_publishable_key = "sb_publishable_..."
# supabase_secret_key    = "sb_secret_..."  # optional; backend uses direct Postgres today

# --- HTTPS (recommended for the iOS app) ---
# Set domain_name + point a CNAME in Cloudflare to alb_dns_name (DNS only).
# terraform apply outputs acm_validation_records — add that CNAME in Cloudflare, then re-apply.
# domain_name     = "api.yourdomain.com"
# public_base_url = "https://api.yourdomain.com"
# route53_zone_id = "Z0123456789ABCDEFGHIJ"  # optional; omit when using Cloudflare DNS

# With no domain: apply once, grab alb_dns_name, then set and re-apply:
# public_base_url = "http://pisah-alb-xxxx.ap-southeast-1.elb.amazonaws.com"

# GitHub Actions OIDC (output: github_actions_role_arn → workflow AWS_ROLE_ARN)
# github_repository         = "Xinnan-Alex/pisah"
# github_deploy_branch      = "main"
# create_github_oidc_provider = false  # if OIDC provider already exists in the account
