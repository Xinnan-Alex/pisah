# PROD — copy to .env on your server / set as deploy secrets.
# Values come from the Supabase dashboard: Project Settings → Database / API.

# Use the POOLER connection string (Transaction mode, port 6543) for serverless /
# many-connection hosts; the direct 5432 string is fine for a long-lived server.
DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Project URL — backend fetches JWKS here to verify owner tokens (ES256).
SUPABASE_URL=https://PROJECT_REF.supabase.co

# Anon key — proxies owner sign-in to GoTrue (Project Settings → API → anon public).
SUPABASE_ANON_KEY=eyJ...your-anon-key

# Public URL where THIS backend is deployed — friend share links become <this>/r/<slug>.
PUBLIC_BASE_URL=https://api.yourdomain.com

PORT=8080

# Receipt OCR (AWS Textract)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Legacy HS256 secret — leave blank for modern (asymmetric) Supabase projects.
SUPABASE_JWT_SECRET=
