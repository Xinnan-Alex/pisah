# Pisah backend — copy to .env and fill in. Load with your runner, e.g.:
#   export $(grep -v '^#' .env | xargs) && go run .

# Supabase Postgres connection string (Project Settings → Database → Connection string).
# Use the pooler / "Transaction" string for serverless/many-connection hosts.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Supabase project URL — used to fetch JWKS and verify owner access tokens (ES256).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Anon key — proxies owner sign-in to GoTrue (Project Settings → API → anon public).
SUPABASE_ANON_KEY=

# Legacy HS256 shared secret. Optional — only needed if your project still issues
# HS256 user tokens. Modern projects use asymmetric (ES256) keys via SUPABASE_URL.
SUPABASE_JWT_SECRET=

# Base URL used to build friend share links: <PUBLIC_BASE_URL>/r/<slug>
PUBLIC_BASE_URL=https://split.my

PORT=8080

# Logging: debug | info | warn | error. Format: text (default) or json.
LOG_LEVEL=info
LOG_FORMAT=text

# AWS credentials for Textract AnalyzeExpense (receipt OCR).
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
